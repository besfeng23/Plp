{
  "rewrites": [
    {
      "source": "/booking",
      "destination": "/booking.html"
    },
    {
      "source": "/booking/",
      "destination": "/booking.html"
    },
    {
      "source": "/((?!api/|booking.html|robots.txt|sitemap.xml|favicon.svg|og-image.svg|site.webmanifest).*)",
      "destination": "/index.html"
    }
  ]
}
